# Optional server-side provider keys for universal dictionary lookup.
# Leave these blank to use the no-key fallback providers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Used as the OpenRouter HTTP-Referer header when OpenRouter is enabled.
APP_PUBLIC_URL=http://localhost:3000
